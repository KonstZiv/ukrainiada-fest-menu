# Copy to .env (prod) or .env-dev (local development) and fill in values.
#
# For dev:   cp .env.example .env-dev
# For prod:  cp .env.example .env

# Django
SECRET_KEY=<generate-your-own-secret-key>
ALLOWED_HOSTS=restoran-service.pythoncourse.me

# Database (PostgreSQL)
DB_NAME=festival_menu
DB_USER=fest_user
DB_PASSWORD=<your-db-password>
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Festival business constants (minutes)
KITCHEN_TIMEOUT=10
MANAGER_TIMEOUT=10
PAY_TIMEOUT=15
SPEED_INTERVAL_KITCHEN=15
ACCEPT_TIMEOUT=5
VERIFY_TIMEOUT=5
COOKING_TIMEOUT=15
HANDOFF_TIMEOUT=10
SENIOR_RESPONSE_TIMEOUT=10
