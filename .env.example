# Copy to .env (prod) or .env-dev (local development) and fill in values.
#
# For dev:   cp .env.example .env-dev
# For prod:  cp .env.example .env

# Django
SECRET_KEY=<generate-your-own-secret-key>
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=festival_menu
DB_USER=postgres
DB_PASSWORD=<your-db-password>
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Festival business constants (minutes)
KITCHEN_TIMEOUT=5
MANAGER_TIMEOUT=5
PAY_TIMEOUT=10
SPEED_INTERVAL_KITCHEN=15
