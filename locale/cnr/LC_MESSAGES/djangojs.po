msgid "доставлено"
msgstr "Dostavljeno"

msgid "Ви ще нічого не обрали."
msgstr "Još uvijek nijeste ništa izabrali."

msgid "Перейти до меню"
msgstr "Idite na meni"

msgid "Прострочено"
msgstr "Kasni"

msgid "Терміново!"
msgstr "Hitno!"

msgid "Офлайн-режим — меню може бути застарілим. Замовлення недоступні."
msgstr "Oflajn režim — meni može biti zastario. Porudžbine nijesu dostupne."

msgid "Скасувати замовлення?"
msgstr "Otkažite porudžbinu?"

msgid "Замовлення скасовано"
msgstr "Porudžbina otkazana"

msgid "Всі страви готові!"
msgstr "Sva jela su spremna!"

msgid "Замовлення доставлено! Смачного!"
msgstr "Porudžbina dostavljena! Prijatno!"

msgid "Оплату прийнято. Дякуємо!"
msgstr "Plaćanje prihvaćeno. Hvala!"

msgid "Ваше звернення прийнято"
msgstr "Vaš zahtjev je primljen"

msgid "%(by)s працює над вашим питанням"
msgstr "%(by)s radi na vašem pitanju"

msgid "Вирішено"
msgstr "Riješeno"

msgid "СПЛАЧЕНО"
msgstr "PLAĆENO"

msgid "Live"
msgstr "Live"

msgid "Offline"
msgstr "Offline"

msgid "Нове замовлення #%(order_id)s від клієнта"
msgstr "Nova porudžbina #%(order_id)s od klijenta"

msgid "Готово"
msgstr "Spremno"

msgid "Страва готова:"
msgstr "Jelo je spremno:"

msgid "Замовлення #%(order_id)s готове!"
msgstr "Porudžbina #%(order_id)s je spremna!"

msgid "Готується (%(by)s)"
msgstr "Priprema se (%(by)s)"

msgid "Замовлення #%(order_id)s на кухні"
msgstr "Porudžbina #%(order_id)s je u kuhinji"

msgid "Кухня"
msgstr "Kuhinja"

msgid "Оплата"
msgstr "Plaćanje"

msgid "Замовлення #%(order_id)s скасовано"
msgstr "Porudžbina #%(order_id)s je otkazana"

msgid "Ескалація! %(label)s #%(id)s"
msgstr "Eskalacija! %(label)s #%(id)s"
