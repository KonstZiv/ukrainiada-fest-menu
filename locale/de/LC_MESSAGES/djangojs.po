msgid "доставлено"
msgstr "zugestellt"

msgid "Ви ще нічого не обрали."
msgstr "Sie haben noch nichts ausgewählt."

msgid "Перейти до меню"
msgstr "Zum Menü"

msgid "Прострочено"
msgstr "Überfällig"

msgid "Терміново!"
msgstr "Dringend!"

msgid "Офлайн-режим — меню може бути застарілим. Замовлення недоступні."
msgstr "Offline-Modus — das Menü ist möglicherweise veraltet. Bestellungen sind nicht verfügbar."

msgid "Скасувати замовлення?"
msgstr "Bestellung stornieren?"

msgid "Замовлення скасовано"
msgstr "Bestellung storniert"

msgid "Всі страви готові!"
msgstr "Alle Gerichte sind fertig!"

msgid "Замовлення доставлено! Смачного!"
msgstr "Bestellung zugestellt! Guten Appetit!"

msgid "Оплату прийнято. Дякуємо!"
msgstr "Zahlung akzeptiert. Vielen Dank!"

msgid "Ваше звернення прийнято"
msgstr "Ihre Anfrage wurde entgegengenommen"

msgid "%(by)s працює над вашим питанням"
msgstr "%(by)s bearbeitet Ihre Anfrage"

msgid "Вирішено"
msgstr "Gelöst"

msgid "СПЛАЧЕНО"
msgstr "BEZAHLT"

msgid "Live"
msgstr "Live"

msgid "Offline"
msgstr "Offline"

msgid "Нове замовлення #%(order_id)s від клієнта"
msgstr "Neue Bestellung #%(order_id)s von einem Kunden"

msgid "Готово"
msgstr "Fertig"

msgid "Страва готова:"
msgstr "Gericht fertig:"

msgid "Замовлення #%(order_id)s готове!"
msgstr "Bestellung #%(order_id)s ist fertig!"

msgid "Готується (%(by)s)"
msgstr "In Zubereitung (%(by)s)"

msgid "Замовлення #%(order_id)s на кухні"
msgstr "Bestellung #%(order_id)s in der Küche"

msgid "Кухня"
msgstr "Küche"

msgid "Оплата"
msgstr "Bezahlung"

msgid "Замовлення #%(order_id)s скасовано"
msgstr "Bestellung #%(order_id)s storniert"

msgid "Ескалація! %(label)s #%(id)s"
msgstr "Eskalation! %(label)s #%(id)s"
