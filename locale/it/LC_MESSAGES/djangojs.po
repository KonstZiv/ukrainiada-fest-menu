msgid "доставлено"
msgstr "consegnato"

msgid "Ви ще нічого не обрали."
msgstr "Non hai ancora scelto nulla."

msgid "Перейти до меню"
msgstr "Vai al menu"

msgid "Прострочено"
msgstr "Scaduto"

msgid "Терміново!"
msgstr "Urgente!"

msgid "Офлайн-режим — меню може бути застарілим. Замовлення недоступні."
msgstr "Modalità offline — il menu potrebbe non essere aggiornato. Gli ordini non sono disponibili."

msgid "Скасувати замовлення?"
msgstr "Annullare l'ordine?"

msgid "Замовлення скасовано"
msgstr "Ordine annullato"

msgid "Всі страви готові!"
msgstr "Tutti i piatti sono pronti!"

msgid "Замовлення доставлено! Смачного!"
msgstr "Ordine consegnato! Buon appetito!"

msgid "Оплату прийнято. Дякуємо!"
msgstr "Pagamento accettato. Grazie!"

msgid "Ваше звернення прийнято"
msgstr "La tua richiesta è stata accettata"

msgid "%(by)s працює над вашим питанням"
msgstr "%(by)s sta lavorando alla tua richiesta"

msgid "Вирішено"
msgstr "Risolto"

msgid "СПЛАЧЕНО"
msgstr "PAGATO"

msgid "Live"
msgstr "Live"

msgid "Offline"
msgstr "Offline"

msgid "Нове замовлення #%(order_id)s від клієнта"
msgstr "Nuovo ordine #%(order_id)s dal cliente"

msgid "Готово"
msgstr "Pronto"

msgid "Страва готова:"
msgstr "Piatto pronto:"

msgid "Замовлення #%(order_id)s готове!"
msgstr "L'ordine #%(order_id)s è pronto!"

msgid "Готується (%(by)s)"
msgstr "In preparazione (%(by)s)"

msgid "Замовлення #%(order_id)s на кухні"
msgstr "Ordine #%(order_id)s in cucina"

msgid "Кухня"
msgstr "Cucina"

msgid "Оплата"
msgstr "Pagamento"

msgid "Замовлення #%(order_id)s скасовано"
msgstr "Ordine #%(order_id)s annullato"

msgid "Ескалація! %(label)s #%(id)s"
msgstr "Escalation! %(label)s #%(id)s"
