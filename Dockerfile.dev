# Lightweight dev image for Celery worker/beat.
# Source code is mounted as a volume — no COPY needed.

FROM python:3.14-slim

COPY --from=ghcr.io/astral-sh/uv:0.10.10 /uv /uvx /bin/

# gettext for compilemessages
RUN apt-get update && apt-get install -y --no-install-recommends gettext && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Install deps on first run (volumes mount brings pyproject.toml + uv.lock).
# Using entrypoint script to sync before running the command.
COPY <<'EOF' /entrypoint.sh
#!/bin/bash
set -e
uv sync --no-install-project --no-editable --group dev
exec "$@"
EOF
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
